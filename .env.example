# ----------------------------------------------------------------------------
# Banco de dados (MySQL) — usado pelo Prisma
# Formato: mysql://USUARIO:SENHA@HOST:PORTA/NOME_DO_BANCO
# Ex. para o MySQL local instalado no Windows (MySQL 8.0):
# ----------------------------------------------------------------------------
DATABASE_URL="mysql://root:SUA_SENHA@localhost:3306/edugestao"

# ----------------------------------------------------------------------------
# Sessão / Autenticação
# Gere um segredo forte: `openssl rand -base64 48`
# ----------------------------------------------------------------------------
AUTH_SECRET="troque-este-segredo-por-uma-string-longa-e-aleatoria"
# Duração da sessão em segundos (padrão: 7 dias)
SESSION_MAX_AGE="604800"

# ----------------------------------------------------------------------------
# Integração com IA (provider configurável)
# Funciona com qualquer endpoint compatível com a API OpenAI Chat Completions
# (OpenAI, OpenRouter, Groq, Together, modelos locais via Ollama/LM Studio...)
# ----------------------------------------------------------------------------
AI_PROVIDER="openai"
AI_API_KEY=""
AI_BASE_URL="https://api.openai.com/v1"
AI_MODEL="gpt-4o-mini"
# Limite de tokens da resposta da IA
AI_MAX_TOKENS="1200"

# ----------------------------------------------------------------------------
# App
# ----------------------------------------------------------------------------
NEXT_PUBLIC_APP_NAME="EduGestão IA"
